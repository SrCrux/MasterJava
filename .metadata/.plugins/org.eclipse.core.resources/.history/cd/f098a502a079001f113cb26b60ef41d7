package com.ejerciciosclase.ejerciciorectangulo;

public class Rectangulo {

	private int largo;
	private int ancho;

	public Rectangulo() {
		this.largo = 6;
		this.ancho = 4;
	}

	public Rectangulo(int largo, int ancho) {
		super();

		if (largo > 0 && ancho > 0) {
			this.largo = largo;
			this.ancho = ancho;

		} else {

			this.largo = 6;
			this.ancho = 4;

		}

	}

	public int getLargo() {
		return largo;
	}

	public void setLargo(int largo) {

		if (largo > 0) {
			this.largo = largo;
		}
	}

	public int getAncho() {
		return ancho;
	}

	public void setAncho(int ancho) {
		if (ancho > 0) {
			this.ancho = ancho;
		}
	}

}
